<% layout("/layouts/boilerplate.ejs") %>

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4 p-4">
            
            <h3 class="text-center mb-4">Create Account</h3>

           <form method="POST" action="/signup" novalidate class="needs-validation">

    <div class="mb-3">
        <label class="form-label">Username</label>
        <input name="user[username]" type="text" class="form-control rounded-3" required>
        <div class="invalid-feedback">Username is required.</div>
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="user[email]" type="email" class="form-control rounded-3" required>
        <div class="invalid-feedback">Enter a valid email.</div>
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <input name="user[password]" type="password" class="form-control rounded-3" required minlength="6">
        <div class="invalid-feedback">Minimum 6 characters required.</div>
    </div>

    <button class="btn btn-dark w-100 rounded-3 mt-3">Sign Up</button>

    <div class="text-center mt-3">
        <small>
            Already have an account? 
            <a href="/login" class="text-decoration-none fw-semibold">Login</a>
        </small>
    </div>

</form>
        </div>
    </div>
</div>
